{
  "private": true,
  "name": "alianhubtimetracker",
  "description": "My application description",
  "version": "5.0.0",
  "author": "Alian Software",
  "homepage": "https://aliansoftware.com",
  "main": "app/background.js",
  "executableName": "alianhubtimetracker",
  
  "engines": {
    "node": "18.17.0",
    "npm": "9.6.7"
  },
  
  "scripts": {
    "dev": "nextron",
    "build": "nextron build",
    "build:linux": "nextron build --linux",
    "postinstall": "electron-builder install-app-deps && bash postinstall.sh"
  },
  "build": {
    "mac": {
      "icon": "resources/logo.png",
      "category": "public.app-category.utilities",
      "extraResources": [
        {
          "from": "macOS/Info.plist",
          "to": "Contents/Info.plist"
        }
      ],
      "protocols": [
        {
          "name": "myapp Protocol",
          "schemes": [
            "myapp"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "protocols": [
        {
          "name": "myapp Protocol",
          "schemes": [
            "myapp"
          ]
        }
      ],
      "category": "Utility",
      "maintainer": "Alian Software <support@alianhub.com>",
      "description": "Your app description",
      "executableName": "alianhubtimetracker",
      "desktop": {
        "Type": "Application",
        "Name": "alianhubtimetracker",
        "Terminal": false,
        "MimeType": "x-scheme-handler/myapp;",
        "Icon": "myapp",
        "StartupNotify": true
      }
    },
    "win": {
      "icon": "resources/logo.png",
      "protocols": [
        {
          "name": "myapp Protocol",
          "schemes": [
            "myapp"
          ]
        }
      ],
      "certificateFile": "C:/mycert.pfx",
      "certificatePassword": "YourPassword123"
    }
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.6.1",
    "@tailwindcss/postcss": "^4.0.13",
    "axios": "^1.8.3",
    "electron-serve": "^1.3.0",
    "electron-store": "^8.2.0",
    "fs": "^0.0.1-security",
    "luxon": "^3.5.0",
    "moment": "^2.30.1",
    "node-global-key-listener": "^0.3.0",
    "postcss": "^8.5.3",
    "react-redux": "^9.2.0",
    "react-select": "^5.10.1",
    "tailwindcss": "^4.0.13"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3",
    "next": "^14.2.35",
    "nextron": "^9.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
